{
  "name": "veilpledge",
  "version": "1.0.0",
  "type": "module",
  "description": "A Midnight Network application created with create-mn-app",
  "author": "",
  "license": "MIT",
  "scripts": {
    "compile": "compact compile contracts/veilpledge.compact contracts/managed/veilpledge",
    "build": "npm run typecheck && npm run web:build",
    "setup": "npx tsx src/setup.ts",
    "deploy": "npx tsx src/deploy.ts",
    "cli": "npx tsx src/cli.ts",
    "check-balance": "npx tsx src/check-balance.ts",
    "network": "npx tsx src/network.ts",
    "proof-server:start": "docker compose up -d",
    "proof-server:stop": "docker compose down",
    "clean": "rm -rf contracts/managed .midnight-state.json .midnight-state.json.tmp-* .midnight-wallet-state midnight-level-db web/dist web/.vite web/public/keys web/public/zkir web/src/generated",
    "test": "npm run test:contract && npm run web:test",
    "test:contract": "vitest run tests",
    "test:watch": "vitest tests",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx scripts/e2e-check.ts",
    "users": "tsx scripts/preprod-users.ts",
    "web:prepare": "node scripts/prepare-web-assets.mjs",
    "web:dev": "npm run web:prepare && vite --config web/vite.config.ts",
    "web:typecheck": "tsc -p web/tsconfig.json --noEmit",
    "web:test": "vitest run --config web/vitest.config.ts",
    "web:build": "npm run web:prepare && npm run web:typecheck && vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts"
  },
  "dependencies": {
    "@fontsource/manrope": "5.2.8",
    "@fontsource/newsreader": "5.2.9",
    "@midnight-ntwrk/compact-js": "2.5.1",
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.1.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.1.1",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-protocol": "4.1.1",
    "@midnight-ntwrk/midnight-js-types": "4.1.1",
    "@midnight-ntwrk/midnight-js-utils": "4.1.1",
    "@midnight-ntwrk/wallet-sdk-abstractions": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "4.2.0",
    "@midnight-ntwrk/wallet-sdk-facade": "4.1.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.2",
    "@midnight-ntwrk/wallet-sdk-indexer-client": "1.2.3",
    "@midnight-ntwrk/wallet-sdk-shielded": "3.0.2",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "3.1.0",
    "buffer": "6.0.3",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rxjs": "^7.8.2",
    "semver": "7.8.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "rollup": "4.62.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "8.1.4",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "vite-plugin-top-level-await": {
      "uuid": "11.1.1"
    }
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "privacy"
  ]
}
