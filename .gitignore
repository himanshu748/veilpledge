.vscode/settings.json
.idea/
*.swp
*.swo

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/

# Private state
*-state/

# Temporary files
tmp/
temp/

# Midnight network state (per-network seeds, deploy addresses)
.midnight-state.json
.midnight-state.json.tmp-*

# Midnight wallet sync state (per-network serialized wallet state cache)
.midnight-wallet-state/

# Encrypted private contract state and signing keys
midnight-level-db/
